<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/calendar_diagnostics_fragment"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingHorizontal="@dimen/activity_margin">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <org.fossify.commons.views.MyTextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/calendar_diagnostics_title"
            android:textSize="@dimen/big_text_size"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/calendar_diagnostics_refresh"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sync_calendar_now" />

    </LinearLayout>

    <ProgressBar
        android:id="@+id/calendar_diagnostics_progress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:visibility="gone" />

    <org.fossify.commons.views.MyTextView
        android:id="@+id/calendar_diagnostics_permission_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="@dimen/normal_margin"
        android:text="@string/calendar_diagnostics_permission_message"
        android:visibility="gone" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/calendar_diagnostics_grant_permission"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/allow_calendar_access"
        android:visibility="gone" />

    <org.fossify.commons.views.MyTextView
        android:id="@+id/calendar_diagnostics_provider_error"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="@dimen/normal_margin"
        android:textStyle="bold"
        android:visibility="gone"
        tools:text="Calendar provider error" />

    <LinearLayout
        android:id="@+id/calendar_diagnostics_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="@dimen/normal_margin"
        android:visibility="gone">

        <org.fossify.commons.views.MyTextView
            android:id="@+id/calendar_diagnostics_window"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            tools:text="Alarm window: Jul 23 – Aug 7" />

        <org.fossify.commons.views.MyTextView
            android:id="@+id/calendar_diagnostics_query_window"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:alpha="0.75"
            android:paddingTop="@dimen/tiny_margin"
            tools:text="Calendar scan: Jul 8 – Aug 22" />

        <org.fossify.commons.views.MyTextView
            android:id="@+id/calendar_diagnostics_counts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="@dimen/normal_margin"
            tools:text="12 events · 4 alarms" />

        <org.fossify.commons.views.MyTextView
            android:id="@+id/calendar_diagnostics_health"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:alpha="0.8"
            android:paddingTop="@dimen/tiny_margin"
            tools:text="4 exact · 0 drifted · 0 unlinked" />

        <org.fossify.commons.views.MyTextView
            android:id="@+id/calendar_diagnostics_captured"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:alpha="0.7"
            android:paddingTop="@dimen/tiny_margin"
            tools:text="Read at Jul 23, 16:00" />

        <org.fossify.commons.views.MyTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:alpha="0.7"
            android:paddingTop="@dimen/normal_margin"
            android:text="@string/calendar_diagnostics_alarm_manager_note"
            android:textStyle="italic" />

    </LinearLayout>

    <org.fossify.commons.views.MyTextView
        android:id="@+id/calendar_diagnostics_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="@dimen/activity_margin"
        android:text="@string/calendar_diagnostics_empty"
        android:textSize="@dimen/bigger_text_size"
        android:textStyle="italic"
        android:visibility="gone" />

    <org.fossify.commons.views.MyRecyclerView
        android:id="@+id/calendar_diagnostics_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:overScrollMode="ifContentScrolls"
        android:paddingBottom="@dimen/activity_margin"
        android:scrollbars="none"
        android:visibility="gone"
        app:layoutManager="org.fossify.commons.views.MyLinearLayoutManager"
        tools:listitem="@layout/item_calendar_diagnostics_event" />

</LinearLayout>
