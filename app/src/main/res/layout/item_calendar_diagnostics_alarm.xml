<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="66dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingVertical="@dimen/small_margin">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/calendar_diagnostics_alarm_color"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_marginEnd="@dimen/normal_margin"
            app:cardCornerRadius="6dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/color_primary"
            app:strokeWidth="1dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <org.fossify.commons.views.MyTextView
                    android:id="@+id/calendar_diagnostics_alarm_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textStyle="bold"
                    tools:text="Team meeting" />

                <org.fossify.commons.views.MyTextView
                    android:id="@+id/calendar_diagnostics_alarm_trigger"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/normal_margin"
                    android:maxLines="1"
                    android:textStyle="bold"
                    tools:text="14:00" />

            </LinearLayout>

            <org.fossify.commons.views.MyTextView
                android:id="@+id/calendar_diagnostics_alarm_details"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:alpha="0.7"
                android:ellipsize="end"
                android:maxLines="1"
                android:paddingTop="@dimen/tiny_margin"
                tools:text="Jul 23 · 1 h before · event at 15:00" />

            <org.fossify.commons.views.MyTextView
                android:id="@+id/calendar_diagnostics_alarm_warning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="@dimen/small_margin"
                android:textStyle="bold"
                android:visibility="gone"
                tools:text="Calendar event not found"
                tools:visibility="visible" />

        </LinearLayout>

    </LinearLayout>

    <View
        android:id="@+id/calendar_diagnostics_alarm_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:alpha="0.12" />

</LinearLayout>
