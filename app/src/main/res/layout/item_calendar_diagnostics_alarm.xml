<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/tiny_margin"
    app:cardCornerRadius="@dimen/normal_margin"
    app:cardElevation="0dp"
    app:strokeColor="@color/color_primary"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="76dp"
        android:orientation="horizontal">

        <View
            android:id="@+id/calendar_diagnostics_alarm_color"
            android:layout_width="5dp"
            android:layout_height="match_parent"
            android:background="@color/color_primary" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/normal_margin"
            android:paddingVertical="@dimen/small_margin">

            <org.fossify.commons.views.MyTextView
                android:id="@+id/calendar_diagnostics_alarm_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textStyle="bold"
                tools:text="Team meeting" />

            <org.fossify.commons.views.MyTextView
                android:id="@+id/calendar_diagnostics_alarm_trigger"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="@dimen/tiny_margin"
                tools:text="Jul 23, 2026, 14:00" />

            <org.fossify.commons.views.MyTextView
                android:id="@+id/calendar_diagnostics_alarm_details"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:alpha="0.75"
                android:ellipsize="end"
                android:maxLines="1"
                android:paddingTop="@dimen/tiny_margin"
                tools:text="1 h before event · Event starts: Jul 23, 2026, 15:00" />

            <org.fossify.commons.views.MyTextView
                android:id="@+id/calendar_diagnostics_alarm_warning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="@dimen/tiny_margin"
                android:textStyle="bold"
                android:visibility="gone"
                tools:text="Metadata drift"
                tools:visibility="visible" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
