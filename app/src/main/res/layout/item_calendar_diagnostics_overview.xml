<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="@dimen/small_margin"
    android:paddingBottom="@dimen/small_margin">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:minHeight="48dp"
        android:orientation="horizontal">

        <org.fossify.commons.views.MyTextView
            android:id="@+id/calendar_diagnostics_overview_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/calendar"
            android:textSize="@dimen/bigger_text_size"
            android:textStyle="bold" />

        <ProgressBar
            android:id="@+id/calendar_diagnostics_overview_progress"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginHorizontal="8dp"
            android:visibility="gone" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/calendar_diagnostics_overview_refresh"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/sync_calendar_now"
            android:padding="12dp"
            android:src="@drawable/ic_refresh_vector" />

    </LinearLayout>

    <org.fossify.commons.views.MyTextView
        android:id="@+id/calendar_diagnostics_overview_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textStyle="bold"
        tools:text="4 planned alarms · 12 events" />

    <org.fossify.commons.views.MyTextView
        android:id="@+id/calendar_diagnostics_overview_meta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:alpha="0.7"
        android:ellipsize="end"
        android:maxLines="1"
        android:paddingTop="@dimen/tiny_margin"
        tools:text="Jul 23 – Aug 7 · Checked at 16:08" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/calendar_diagnostics_overview_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/small_margin"
        android:visibility="gone"
        app:cardCornerRadius="@dimen/normal_margin"
        app:cardElevation="0dp"
        app:strokeColor="@color/color_primary"
        app:strokeWidth="1dp"
        tools:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/normal_margin"
            android:paddingVertical="@dimen/small_margin">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <org.fossify.commons.views.MyTextView
                    android:id="@+id/calendar_diagnostics_overview_status_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textStyle="bold"
                    tools:text="Calendar event not found" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/calendar_diagnostics_overview_status_action"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minHeight="40dp"
                    android:text="@string/sync_calendar_now" />

            </LinearLayout>

            <org.fossify.commons.views.MyTextView
                android:id="@+id/calendar_diagnostics_overview_status_details"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/tiny_margin"
                android:lineSpacingExtra="1dp"
                tools:text="The alarm still exists, but its calendar event may have been deleted or moved." />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
